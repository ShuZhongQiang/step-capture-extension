{
  "manifest_version": 3,
  "name": "步骤图录制器",
  "version": "1.0.0",
  "description": "记录浏览器操作步骤并生成指南",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "icons/steps.png",
      "48": "icons/steps48.png",
      "128": "icons/steps128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/jszip.min.js", "lib/html2canvas.min.js", "content.js"]
    }
  ],
  "icons": {
    "16": "icons/steps.png",
    "48": "icons/steps48.png",
    "128": "icons/steps128.png"
  }
}
